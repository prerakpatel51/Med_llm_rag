{
  "title": "Medical Lit Assistant – Overview",
  "uid": "medlit-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(medlit_requests_total[5m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (errors/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(medlit_errors_total[5m])",
          "legendFormat": "{{error_type}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency Percentiles (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "job:medlit_request_latency_p50:5m", "legendFormat": "p50" },
        { "expr": "job:medlit_request_latency_p95:5m", "legendFormat": "p95" },
        { "expr": "job:medlit_request_latency_p99:5m", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [
        { "expr": "medlit_active_requests", "legendFormat": "Active" }
      ]
    },
    {
      "id": 5,
      "title": "Memory Records",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [
        { "expr": "medlit_memory_records_total", "legendFormat": "Records" }
      ]
    },
    {
      "id": 6,
      "title": "Tokens In/Out (total)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(medlit_tokens_in_total[5m])", "legendFormat": "Tokens In/s" },
        { "expr": "rate(medlit_tokens_out_total[5m])", "legendFormat": "Tokens Out/s" }
      ]
    },
    {
      "id": 7,
      "title": "Queries by Topic",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, rate(medlit_topic_queries_total[1h]))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Documents in DB",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "targets": [
        { "expr": "medlit_documents_stored_total", "legendFormat": "Documents" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "blue" }] } } }
    },
    {
      "id": 12,
      "title": "Chunks in DB",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "targets": [
        { "expr": "medlit_chunks_stored_total", "legendFormat": "Chunks" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "green" }] } } }
    },
    {
      "id": 8,
      "title": "Host Memory Usage %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent" } }
    },
    {
      "id": 9,
      "title": "Host CPU Usage %",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent" } }
    },
    {
      "id": 10,
      "title": "Disk Usage %",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{mountpoint='/'} - node_filesystem_free_bytes{mountpoint='/'}) / node_filesystem_size_bytes{mountpoint='/'} * 100",
          "legendFormat": "Disk %"
        }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent" } }
    }
  ]
}
