# ── Stage 1: install dependencies ────────────────────────────────────────────
FROM node:20-alpine AS deps
WORKDIR /app

COPY package.json ./
RUN npm install


# ── Stage 2: build the Next.js app ───────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# BACKEND_URL is baked in at build time for rewrites in next.config.js.
# The /api rewrites use this to proxy requests to the backend container.
ENV BACKEND_URL=http://backend:8000

RUN npm run build


# ── Stage 3: minimal production image ────────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

# Next.js standalone output includes only the files needed to run the server.
# This keeps the image small (~150 MB vs ~1 GB without standalone).
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

# server.js is generated by Next.js in standalone mode
CMD ["node", "server.js"]
