# --- Database ---
DATABASE_URL=postgresql+asyncpg://medlit:medlit@postgres:5432/medlit
POSTGRES_USER=medlit
POSTGRES_PASSWORD=medlit
POSTGRES_DB=medlit

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:1b
# Stop Ollama container after this many seconds idle (saves ~800 MB RAM)
# 600 = 10 min, 300 = 5 min, 1800 = 30 min
OLLAMA_IDLE_TIMEOUT=600

# --- NCBI / PubMed (get free key at https://www.ncbi.nlm.nih.gov/account/) ---
NCBI_API_KEY=your-ncbi-api-key-here
NCBI_EMAIL=you@example.com

# --- App ---
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=admin
