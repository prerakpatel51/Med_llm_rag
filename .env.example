# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://medlit:medlit@postgres:5432/medlit
POSTGRES_USER=medlit
POSTGRES_PASSWORD=medlit
POSTGRES_DB=medlit

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b
# Stop Ollama container after this many seconds idle (saves RAM)
# 300 = 5 min recommended for spot GPU
OLLAMA_IDLE_TIMEOUT=300

# ── NCBI / PubMed ─────────────────────────────────────────────────────────────
# Get a free API key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your-ncbi-api-key-here
NCBI_EMAIL=your-email@example.com

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change-me-in-production

# ── AWS (needed for spot GPU EC2 management) ──────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
GPU_INSTANCE_TYPE=g4dn.xlarge
GPU_AMI_ID=your-custom-ami-id-here
GPU_SPOT_MAX_PRICE=0.30
GPU_IDLE_TIMEOUT=300
